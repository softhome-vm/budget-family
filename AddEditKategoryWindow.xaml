<Window x:Class="Budget.AddEditKategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Категория" Height="316" Width="370"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Border Margin="15" CornerRadius="12" Background="White"
            BorderBrush="#CBD5E1" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#7C3AED" BlurRadius="12" ShadowDepth="3" Opacity="0.12"/>
        </Border.Effect>

        <StackPanel Margin="15">
            <TextBlock Text="Категория" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource TitleGradientBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="Название категории:" Style="{DynamicResource FieldLabelStyle}" Margin="0,0,0,5"/>
            <TextBox x:Name="NameKategoryTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Тип категории:" Style="{DynamicResource FieldLabelStyle}" Margin="0,0,0,5"/>
            <ComboBox x:Name="TypeComboBox" Margin="0,0,0,15" SelectedIndex="0">
                <ComboBoxItem Content="Расход" Tag="False"/>
                <ComboBoxItem Content="Доход" Tag="True"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить" Width="110" Height="36" Margin="0,0,10,0" Click="SaveClick"
                        Style="{DynamicResource SaveButtonStyle}"/>
                <Button Content="Отмена" Width="110" Height="36" Click="CancelClick"
                        Style="{DynamicResource CancelButtonStyle}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
