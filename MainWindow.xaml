<Window x:Class="Budget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Бюджет семьи" Height="500" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        ResizeMode="CanMinimize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="0,0,20,20" Padding="0,30,0,30">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4A6CF7" Offset="0"/>
                    <GradientStop Color="#7C3AED" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="budget_icon.png" Width="60" Height="60" Margin="0,0,20,0"
                       Stretch="UniformToFill"/>
                <TextBlock Text="Управление семейным бюджетом"
                           FontSize="26" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1" Text="Выберите раздел для работы"
                   FontSize="15" Foreground="#64748B" FontWeight="Medium"
                   HorizontalAlignment="Center"
                   Margin="0,25,0,20"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Button Content="Аккаунты" Style="{DynamicResource NavButtonStyle}" Click="Accounts"/>
            <Button Content="Бюджет" Style="{DynamicResource NavButtonStyle}" Click="BudgetsClick"/>
            <Button Content="Члены семьи" Style="{DynamicResource NavButtonStyle}" Click="Families"/>
            <Button Content="Категории" Style="{DynamicResource NavButtonStyle}" Click="KategoriesClick"/>
            <Button Content="Транзакции" Style="{DynamicResource NavButtonStyle}" Click="TransitionsClick"/>
        </StackPanel>
    </Grid>
</Window>
